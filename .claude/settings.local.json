{
  "permissions": {
    "allow": [
      "Bash(npm run start)",
      "Bash(npm run android)",
      "Bash(npm test*)",
      "Bash(npm run test:watch)",
      "Bash(npm run icons)",
      "Bash(npx expo *)",
      "Bash(npx tsc --noEmit*)",
      "Bash(npx jest *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      { "matcher": "Bash", "hooks": [{ "type": "command", "command": "bash .claude/hooks/block-env-commit.sh" }] },
      { "matcher": "Write|Edit", "hooks": [{ "type": "command", "command": "bash .claude/hooks/block-service-key.sh" }] }
    ],
    "PostToolUse": [
      { "matcher": "Edit|Write", "hooks": [
        { "type": "command", "command": "bash .claude/hooks/lint-on-write.sh" },
        { "type": "command", "command": "bash .claude/hooks/test-on-write.sh" }
      ] }
    ]
  }
}
